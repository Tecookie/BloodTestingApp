<Window x:Class="BloodTestingApp.Pages.Admin.UserManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Tài Khoản Toàn Diện" Height="650" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="#DEE2E6" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="THÔNG TIN TÀI KHOẢN &amp; CHI TIẾT" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#212529"/>
                <UniformGrid Columns="3">
                    <StackPanel Margin="5">
                        <Label Content="Tên đăng nhập:"/>
                        <TextBox x:Name="txtUsername" Padding="5"/>

                        <Label Content="Mật khẩu (Để trống mặc định là 1):" Margin="0,5,0,0"/>
                        <PasswordBox x:Name="txtPassword" Padding="5"/>

                        <Label Content="Vai trò (Role):" Margin="0,5,0,0"/>
                        <ComboBox x:Name="cbRole" Padding="5" SelectionChanged="cbRole_SelectionChanged">
                            <ComboBoxItem Content="ADMIN"/>
                            <ComboBoxItem Content="DOCTOR"/>
                            <ComboBoxItem Content="CUSTOMER"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Họ và Tên:"/>
                        <TextBox x:Name="txtFullName" Padding="5"/>
                        <Label x:Name="lblSubInfo" Content="Thông tin thêm (SĐT/Chuyên khoa):" Margin="0,5,0,0"/>
                        <TextBox x:Name="txtSubInfo" Padding="5"/>
                    </StackPanel>

                    <StackPanel Margin="5" VerticalAlignment="Bottom">
                        <UniformGrid Columns="2">
                            <Button x:Name="btnAdd" Content="Thêm mới" Margin="2" Height="35" Click="btnAdd_Click" Background="#28A745" Foreground="White" BorderThickness="0"/>
                            <Button x:Name="btnUpdate" Content="Cập nhật" Margin="2" Height="35" Click="btnUpdate_Click" Background="#007BFF" Foreground="White" BorderThickness="0"/>
                            <Button x:Name="btnDelete" Content="Xóa" Margin="2" Height="35" Click="btnDelete_Click" Background="#DC3545" Foreground="White" BorderThickness="0"/>
                            <Button x:Name="btnClear" Content="Làm lại" Margin="2" Height="35" Click="btnClear_Click" Background="#6C757D" Foreground="White" BorderThickness="0"/>
                        </UniformGrid>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgUsers" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionChanged="dgUsers_SelectionChanged" 
                  GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DEE2E6">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Tài khoản" Binding="{Binding Username}" Width="150"/>
                <DataGridTextColumn Header="Vai trò" Binding="{Binding Role}" Width="100"/>

                <DataGridTemplateColumn Header="Họ và Tên" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Customer.FullName}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="DOCTOR">
                                                <Setter Property="Text" Value="{Binding Doctor.FullName}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="ADMIN">
                                                <Setter Property="Text" Value="Quản trị viên" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>