<Window x:Class="BloodTestingApp.Pages.Admin.UserManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Tài Khoản Toàn Diện"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#1A2235"/>
            <Setter Property="BorderBrush" Value="#D0D8E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="CaretBrush" Value="#2E6ECC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2E6ECC"/>
                                <Setter Property="Background" Value="#EEF3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldPwd" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#1A2235"/>
            <Setter Property="BorderBrush" Value="#D0D8E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="CaretBrush" Value="#2E6ECC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2E6ECC"/>
                                <Setter Property="Background" Value="#EEF3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E6ECC"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,10,0,5"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2A3550"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF3FC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDEAFF"/>
                    <Setter Property="Foreground" Value="#1A4FAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Background="#F0F4FA" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.15" Color="#1A3A7A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A4FAA" Offset="0"/>
                        <GradientStop Color="#2260CC" Offset="0.6"/>
                        <GradientStop Color="#E8365D" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="🩸" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="QUẢN LÝ TÀI KHOẢN" FontSize="15" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="/ BloodTestingApp" FontSize="11" Foreground="#AACCFF"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <Button Content="Logout"
        Width="100"
        Height="35"
        HorizontalAlignment="Right"
        Margin="0,10,10,0"
        Click="Logout_Click"/>
                <Button Content="—" Width="30" Height="26" Margin="2,0" Click="btnMinimize_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFFFFF30"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFFFFF50"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="✕" Width="30" Height="26" Margin="2,0" Click="btnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFFFFF30"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#CC2040"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- FORM PANEL -->
            <Border Grid.Row="1" Margin="16,14,16,0" CornerRadius="10"
                    Background="White" BorderBrush="#D8E4F4" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.07" Color="#1A3A7A"/>
                </Border.Effect>
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <!-- Col 0: Account -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="THÔNG TIN ĐĂNG NHẬP" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <TextBlock Text="TÀI KHOẢN" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource FieldBox}"/>
                        <TextBlock Text="MẬT KHẨU  (mặc định: 1)" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource FieldPwd}"/>
                        <TextBlock Text="VAI TRÒ (ROLE)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cbRole" Padding="8,7" Background="#F5F7FA"
                                  BorderBrush="#D0D8E8" BorderThickness="0,0,0,2"
                                  SelectionChanged="cbRole_SelectionChanged">
                            <ComboBoxItem Content="ADMIN"/>
                            <ComboBoxItem Content="DOCTOR"/>
                            <ComboBoxItem Content="CUSTOMER"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Margin="0,4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="0.3"/>
                                <GradientStop Color="#D8E4F4" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Col 1: Personal -->
                    <StackPanel Grid.Column="1" Margin="20,0,20,0">
                        <TextBlock Text="THÔNG TIN CÁ NHÂN" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <TextBlock Text="HỌ VÀ TÊN" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtFullName" Style="{StaticResource FieldBox}"/>
                        <TextBlock x:Name="lblSubInfo" Text="THÔNG TIN THÊM (SĐT / CHUYÊN KHOA)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtSubInfo" Style="{StaticResource FieldBox}"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Margin="0,4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="0.3"/>
                                <GradientStop Color="#D8E4F4" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Col 2: Stats -->
                    <StackPanel Grid.Column="2" Margin="20,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="THỐNG KÊ NHANH" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Border Margin="3" CornerRadius="8" Padding="10,8"
                                    Background="#FFF0F2" BorderBrush="#FFCCD4" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ADMIN" FontSize="9" Foreground="#CC2040" FontWeight="Bold"/>
                                    <TextBlock x:Name="txbAdminCount" Text="—" FontSize="20" Foreground="#E8365D" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="3" CornerRadius="8" Padding="10,8"
                                    Background="#F0FFF6" BorderBrush="#BBEED0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="DOCTOR" FontSize="9" Foreground="#1A8A4A" FontWeight="Bold"/>
                                    <TextBlock x:Name="txbDoctorCount" Text="—" FontSize="20" Foreground="#22AA5C" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="3" CornerRadius="8" Padding="10,8"
                                    Background="#F0F5FF" BorderBrush="#BBCEF0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CUSTOMER" FontSize="9" Foreground="#1A4FAA" FontWeight="Bold"/>
                                    <TextBlock x:Name="txbCustomerCount" Text="—" FontSize="20" Foreground="#2E6ECC" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="3" CornerRadius="8" Padding="10,8"
                                    BorderBrush="#D8E4F4" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EEF3FC" Offset="0"/>
                                        <GradientStop Color="#E4ECFA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="TỔNG" FontSize="9" Foreground="#2E6ECC" FontWeight="Bold"/>
                                    <TextBlock x:Name="txbTotalCount" Text="—" FontSize="20" Foreground="#1A4FAA" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Col 3: Buttons -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="THAO TÁC" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                        <Button x:Name="btnAdd" Content="＋  THÊM MỚI" Margin="0,4"
                                Style="{StaticResource ActionBtn}" Click="btnAdd_Click" Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A8A4A" Offset="0"/>
                                    <GradientStop Color="#22AA5C" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button x:Name="btnUpdate" Content="✎  CẬP NHẬT" Margin="0,4"
                                Style="{StaticResource ActionBtn}" Click="btnUpdate_Click" Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A4FAA" Offset="0"/>
                                    <GradientStop Color="#2E6ECC" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button x:Name="btnDelete" Content="✕  XÓA" Margin="0,4"
                                Style="{StaticResource ActionBtn}" Click="btnDelete_Click" Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#CC2040" Offset="0"/>
                                    <GradientStop Color="#E8365D" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button x:Name="btnClear" Content="↺  LÀM LẠI" Margin="0,4"
                                Style="{StaticResource ActionBtn}" Click="btnClear_Click"
                                Foreground="#6080AA" Background="#EEF3FC"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DATAGRID -->
            <Border Grid.Row="2" Margin="16,12,16,16" CornerRadius="10"
                    Background="White" BorderBrush="#D8E4F4" BorderThickness="1" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.07" Color="#1A3A7A"/>
                </Border.Effect>
                <DataGrid x:Name="dgUsers"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          SelectionChanged="dgUsers_SelectionChanged"
                          Background="Transparent" RowBackground="Transparent"
                          AlternatingRowBackground="#F8FAFF"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAF0FA"
                          BorderThickness="0"
                          RowStyle="{StaticResource DgRow}" CellStyle="{StaticResource DgCell}"
                          RowHeaderWidth="0" SelectionMode="Single" ColumnHeaderHeight="38">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F0F5FF" Offset="0"/>
                                        <GradientStop Color="#E8F0FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#1A4FAA"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#C8D8F0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#8090B8"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TÀI KHOẢN" Binding="{Binding Username}" Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12.5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="VAI TRÒ" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="8,5" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EEF3FC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="ADMIN">
                                                        <Setter Property="Background" Value="#FFF0F2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="DOCTOR">
                                                        <Setter Property="Background" Value="#F0FFF6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#2E6ECC"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="ADMIN">
                                                            <Setter Property="Foreground" Value="#E8365D"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="DOCTOR">
                                                            <Setter Property="Foreground" Value="#1A8A4A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Padding="12,8" FontSize="12.5">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Customer.FullName}"/>
                                                <Setter Property="Foreground" Value="#2A3550"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="DOCTOR">
                                                        <Setter Property="Text" Value="{Binding Doctor.FullName}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="ADMIN">
                                                        <Setter Property="Text" Value="Quản trị viên"/>
                                                        <Setter Property="Foreground" Value="#1A4FAA"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="NGÀY TẠO"
                                            Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#8090B8"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</Window>