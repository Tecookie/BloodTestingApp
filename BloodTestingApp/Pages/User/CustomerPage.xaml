<Page x:Class="BloodTestingApp.Pages.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BloodTestingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CustomerPage">

    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="ĐẶT LỊCH HẸN" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <DatePicker x:Name="dpDate" Margin="0,5"/>
            <TextBox x:Name="txtNote" Margin="0,5" Height="60" Text="Ghi chú triệu chứng..."/>
            <Button Content="Gửi Yêu Cầu" Click="btnSend_Click" Margin="0,10" Background="SkyBlue"/>
        </StackPanel>
    </Grid>
</Page>
