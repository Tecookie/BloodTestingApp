<Page x:Class="BloodTestingApp.Pages.Doctor.DoctorHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BloodTestingApp.Pages.Doctor"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DoctorHistoryPage">

    <Grid Margin="10">
        <DataGrid x:Name="dgHistory"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding AppointmentId}"
                                    Width="50"/>

                <DataGridTextColumn Header="Khách hàng"
                                    Binding="{Binding CustomerName}"
                                    Width="150"/>

                <DataGridTextColumn Header="Thời gian"
                                    Binding="{Binding AppointmentDate}"
                                    Width="150"/>

                <DataGridTextColumn Header="Kết quả"
                                    Binding="{Binding ResultText}"
                                    Width="*"/>

                <DataGridTextColumn Header="Bệnh"
                                    Binding="{Binding Diseases}"
                                    Width="200"/>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</Page>
