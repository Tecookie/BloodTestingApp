<Page x:Class="BloodTestingApp.Pages.Doctor.DoctorAssignedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BloodTestingApp.Pages.Doctor"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DoctorAssignedPage">

    <Grid Margin="10">
        <DataGrid x:Name="dgAssigned"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding AppointmentId}"
                                    Width="50"/>

                <DataGridTextColumn Header="Khách hàng"
                                    Binding="{Binding CustomerName}"
                                    Width="200"/>

                <DataGridTextColumn Header="Thời gian"
                                    Binding="{Binding AppointmentDate}"
                                    Width="180"/>

                <DataGridTemplateColumn Header="Action" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🧪 Nhập kết quả"
                                    Click="Result_Click"
                                    Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
