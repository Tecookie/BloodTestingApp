<Window x:Class="BloodTestingApp.Pages.Doctor.DoctorMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Doctor Dashboard" Height="600" Width="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="Doctor Panel" 
                       Foreground="White" 
                       FontSize="18" 
                       Margin="10"/>
            <Button Content="Logout"
        Width="100"
        Height="35"
        Click="Logout_Click"/>
            <Button Content="📥 Lịch chờ"
                    Margin="10"
                    Click="Pending_Click"/>

            <Button Content="📅 Lịch đã nhận"
                    Margin="10"
                    Click="Assigned_Click"/>

            <Button Content="🧪 Nhập kết quả"
                    Margin="10"
                    Click="Result_Click"/>

            <Button Content="📄 Lịch sử bệnh nhân"
                    Margin="10"
                    Click="History_Click"/>
        </StackPanel>

        <!-- Content -->
        <Frame x:Name="MainFrame" Grid.Column="1"/>
    </Grid>
</Window>