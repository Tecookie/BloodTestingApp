<Page x:Class="BloodTestingApp.Pages.Doctor.DoctorPendingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BloodTestingApp.Pages.Doctor"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DoctorPendingPage">

    <Grid Margin="10">
        <DataGrid x:Name="dgPending" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding AppointmentId}" Width="50"/>
                <DataGridTextColumn Header="Khách hàng" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Thời gian" Binding="{Binding AppointmentDate}" Width="150"/>

                <DataGridTemplateColumn Header="Action" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Accept" 
                                        Margin="5"
                                        Click="Accept_Click"/>
                                <Button Content="Reject" 
                                        Margin="5"
                                        Click="Reject_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
