<Window x:Class="BloodTestingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#F0F2F5">
        <Border Background="White" CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="HỆ THỐNG XÉT NGHIỆM" FontSize="22" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Tên đăng nhập" Margin="0,0,0,5" Foreground="#555"/>
                <TextBox x:Name="txtUsername" Padding="8" Margin="0,0,0,15" BorderBrush="#DDD" BorderThickness="1"/>

                <TextBlock Text="Mật khẩu" Margin="0,0,0,5" Foreground="#555"/>
                <PasswordBox x:Name="txtPassword" Padding="8" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1"/>

                <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnLogin_Click" Cursor="Hand"/>

                <TextBlock x:Name="txtMessage" Foreground="Red" Margin="0,15,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>