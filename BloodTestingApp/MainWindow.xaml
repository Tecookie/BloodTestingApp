<Window x:Class="BloodTestingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" Height="520" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Storyboard x:Key="PulseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.2" To="0.7" Duration="0:0:1.8"
                             AutoReverse="True"/>
        </Storyboard>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#1A2235"/>
            <Setter Property="BorderBrush" Value="#D0D8E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2E6ECC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2E6ECC"/>
                                <Setter Property="Background" Value="#EEF3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#1A2235"/>
            <Setter Property="BorderBrush" Value="#D0D8E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#2E6ECC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2E6ECC"/>
                                <Setter Property="Background" Value="#EEF3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A5CC8" Offset="0"/>
                        <GradientStop Color="#2E7DE8" Offset="0.5"/>
                        <GradientStop Color="#1A5CC8" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="0,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#2E7DE8" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="16" Background="White" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Direction="270" ShadowDepth="8" Opacity="0.18" Color="#2E6ECC"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top accent bar -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A5CC8" Offset="0"/>
                        <GradientStop Color="#E8365D" Offset="0.5"/>
                        <GradientStop Color="#1A5CC8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Close button -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="28" Height="28" Margin="0,0,10,-14"
                    Content="✕" Click="btnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#F0F2F8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#8090B0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8365D"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Main content -->
            <StackPanel Grid.Row="1" Margin="40,30,40,36">

                <!-- Logo -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Ellipse x:Name="LogoGlow" Width="76" Height="76">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#BBDAFF" Offset="0.3"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Border Width="60" Height="60" CornerRadius="30"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderThickness="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF4FF" Offset="0"/>
                                <GradientStop Color="#E0ECFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2E6ECC" Offset="0"/>
                                <GradientStop Color="#E8365D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <TextBlock Text="🩸" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Title -->
                <TextBlock Text="HỆ THỐNG XÉT NGHIỆM" FontSize="19" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A5CC8" Offset="0"/>
                            <GradientStop Color="#E8365D" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="BLOOD TESTING MANAGEMENT" FontSize="9" Foreground="#A0AECB"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Divider -->
                <Border Height="1" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#D8E4F8" Offset="0.3"/>
                            <GradientStop Color="#D8E4F8" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Username -->
                <TextBlock Text="TÊN ĐĂNG NHẬP" FontSize="10" Foreground="#2E6ECC"
                           Margin="2,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,18"/>

                <!-- Password -->
                <TextBlock Text="MẬT KHẨU" FontSize="10" Foreground="#2E6ECC"
                           Margin="2,0,0,6" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,26"/>

                <!-- Login button -->
                <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Height="44"
                        Style="{StaticResource LoginBtn}" Click="btnLogin_Click"/>

                <!-- Error -->
                <TextBlock x:Name="txtMessage" Foreground="#E8365D" Margin="0,12,0,0"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           TextAlignment="Center" FontSize="12"/>

                <!-- Footer -->
                <TextBlock Text="© 2025 BloodTestingApp  •  v2.0" FontSize="10"
                           Foreground="#C0CCDF" HorizontalAlignment="Center" Margin="0,22,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>