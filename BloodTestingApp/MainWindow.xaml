<Window x:Class="BloodTestingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="ĐĂNG NHẬP" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Tài khoản:"/>
            <TextBox x:Name="txtUsername" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Mật khẩu:"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5,0,20" Padding="5"/>

            <Button Content="Đăng nhập" Click="btnLogin_Click" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="txtMessage" Foreground="Red" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>